PORT=3000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/idea_website

# Groq API — used by both blog bot (auto blog generation, cron) and /agent (Carolla chat)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Site Info
SITE_URL=https://yourdomain.com
SITE_NAME=IDEA - Integrated Digital Ecosystem Asia
CONTACT_EMAIL=info@yourdomain.com
CONTACT_PHONE=+62-xxx-xxxx-xxxx
CONTACT_ADDRESS=Your Address, Jakarta, Indonesia

# Blog Bot
BLOG_CRON_SCHEDULE=0 */8 * * *
BLOG_ENABLED=true

# Email (Nodemailer via Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=IDEA Asia <noreply@yourdomain.com>
EMAIL_TO=info@yourdomain.com

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — paste isi content="..." dari metode "HTML tag"
# Contoh: GSC_VERIFICATION=abc123XYZdef-token-verification-googleanda
GSC_VERIFICATION=

# Admin Dashboard
ADMIN_SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# Fonnte (WhatsApp gateway) — untuk admin login OTP
# Dapatkan dari https://fonnte.com/devices (token per-device)
FONNTE_TOKEN=your_fonnte_device_token_here
