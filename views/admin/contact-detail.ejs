<div class="adm-page-header">
  <div>
    <a href="/admin/contacts" style="font-size:12px;color:var(--adm-muted);display:inline-flex;align-items:center;gap:6px;margin-bottom:8px">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Back to Contacts
    </a>
    <h1 class="adm-page-title">Contact from <%= contact.name %></h1>
    <p class="adm-page-sub">Received <%= new Date(contact.createdAt).toLocaleString('en-GB',{day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %> WIB</p>
  </div>
  <div style="display:flex;gap:10px;align-items:center">
    <span class="badge <%= contact.status==='new'?'badge-amber':contact.status==='replied'?'badge-green':contact.status==='archived'?'badge-gray':'badge-blue' %>" style="font-size:13px;padding:6px 14px">
      <%= contact.status %>
    </span>
    <a href="mailto:<%= contact.email %>?subject=Re: Your inquiry to IDEA Asia" class="adm-btn adm-btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V3z" stroke="currentColor" stroke-width="1.3"/><path d="M1 4l6 4.5L13 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Reply via Email
    </a>
  </div>
</div>

<div class="adm-grid-2">
  <!-- Left: Message -->
  <div>
    <div class="contact-detail-card" style="margin-bottom:16px">
      <div style="font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--adm-muted);margin-bottom:16px">Message</div>
      <div class="message-body"><%= contact.message.replace(/\n/g, '<br>') %></div>
    </div>

    <div class="contact-detail-card">
      <div style="font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--adm-muted);margin-bottom:16px">Update Status</div>
      <form action="/admin/contacts/<%= contact._id %>/status" method="POST" style="display:flex;gap:10px;align-items:center">
        <select name="status" class="adm-select" style="flex:1">
          <option value="new"      <%= contact.status==='new'?'selected':'' %>>New</option>
          <option value="read"     <%= contact.status==='read'?'selected':'' %>>Read</option>
          <option value="replied"  <%= contact.status==='replied'?'selected':'' %>>Replied</option>
          <option value="archived" <%= contact.status==='archived'?'selected':'' %>>Archived</option>
        </select>
        <button type="submit" class="adm-btn adm-btn-ghost">Update</button>
      </form>

      <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--adm-border)">
        <form action="/admin/contacts/<%= contact._id %>/delete" method="POST" onsubmit="return confirm('Delete this contact permanently?')">
          <button type="submit" class="adm-btn adm-btn-danger" style="width:100%;justify-content:center">Delete Permanently</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Right: Contact Info -->
  <div>
    <div class="contact-detail-card">
      <div style="font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--adm-muted);margin-bottom:16px">Contact Details</div>

      <div class="contact-field">
        <div class="contact-field-label">Full Name</div>
        <div class="contact-field-value" style="font-size:18px;font-weight:600;color:#fff"><%= contact.name %></div>
      </div>
      <div class="contact-field">
        <div class="contact-field-label">Email</div>
        <div class="contact-field-value">
          <a href="mailto:<%= contact.email %>" style="color:var(--adm-blue)"><%= contact.email %></a>
        </div>
      </div>
      <% if (contact.company) { %>
      <div class="contact-field">
        <div class="contact-field-label">Company</div>
        <div class="contact-field-value"><%= contact.company %></div>
      </div>
      <% } %>
      <% if (contact.phone) { %>
      <div class="contact-field">
        <div class="contact-field-label">Phone</div>
        <div class="contact-field-value"><a href="tel:<%= contact.phone %>" style="color:var(--adm-blue)"><%= contact.phone %></a></div>
      </div>
      <% } %>
      <div class="contact-field">
        <div class="contact-field-label">Service Interest</div>
        <div class="contact-field-value">
          <span class="badge badge-blue"><%= (contact.service||'general').replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %></span>
        </div>
      </div>
      <div class="contact-field">
        <div class="contact-field-label">Language</div>
        <div class="contact-field-value"><%= contact.lang === 'id' ? '🇮🇩 Bahasa Indonesia' : '🇺🇸 English' %></div>
      </div>
      <div class="contact-field">
        <div class="contact-field-label">IP Address</div>
        <div class="contact-field-value" style="color:var(--adm-muted);font-size:12px;font-family:monospace"><%= contact.ip || '—' %></div>
      </div>
      <div class="contact-field">
        <div class="contact-field-label">Submitted</div>
        <div class="contact-field-value" style="color:var(--adm-muted)">
          <%= new Date(contact.createdAt).toLocaleString('en-GB',{dateStyle:'full',timeStyle:'short'}) %>
        </div>
      </div>
    </div>

    <!-- Quick reply hint -->
    <div style="margin-top:16px;padding:16px;background:var(--adm-blue-light);border-radius:var(--radius);border:1px solid rgba(26,80,232,0.2)">
      <p style="font-size:12px;color:rgba(26,80,232,0.9);font-weight:600;margin-bottom:8px">💡 Quick Reply</p>
      <p style="font-size:12px;color:var(--adm-muted);line-height:1.6">Click "Reply via Email" to open your email client with the recipient pre-filled. Don't forget to update the status to "Replied" after responding.</p>
    </div>
  </div>
</div>
