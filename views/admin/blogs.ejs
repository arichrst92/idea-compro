<div class="adm-page-header">
  <div>
    <h1 class="adm-page-title">Blog Posts</h1>
    <p class="adm-page-sub"><%= total %> total posts</p>
  </div>
  <div style="display:flex;gap:10px">
    <form action="/admin/bot/generate" method="POST">
      <button type="submit" class="adm-btn adm-btn-ghost" onclick="return confirm('Generate a new AI blog post now?')">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 1.5a6 6 0 1 1 0 12 6 6 0 0 1 0-12z" stroke="currentColor" stroke-width="1.3"/><path d="M7.5 4.5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        AI Generate
      </button>
    </form>
    <a href="/admin/blogs/new" class="adm-btn adm-btn-primary">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 2v11M2 7.5h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      New Post
    </a>
  </div>
</div>

<!-- Filter bar -->
<form method="GET" action="/admin/blogs">
  <div class="adm-filter-bar">
    <div class="adm-search">
      <svg class="adm-search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/><path d="M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      <input type="text" name="search" placeholder="Search posts..." value="<%= search %>" class="adm-input" style="padding-left:36px">
    </div>
    <select name="category" class="adm-filter-select" onchange="this.form.submit()">
      <option value="">All Categories</option>
      <option value="it-consulting"      <%= category==='it-consulting'?'selected':'' %>>IT Consulting</option>
      <option value="it-outsourcing"     <%= category==='it-outsourcing'?'selected':'' %>>IT Outsourcing</option>
      <option value="it-hiring"          <%= category==='it-hiring'?'selected':'' %>>IT Hiring</option>
      <option value="cloud-infrastructure" <%= category==='cloud-infrastructure'?'selected':'' %>>Cloud Infrastructure</option>
      <option value="it-security"        <%= category==='it-security'?'selected':'' %>>IT Security</option>
      <option value="squad-delivery"     <%= category==='squad-delivery'?'selected':'' %>>Squad Delivery</option>
    </select>
    <button type="submit" class="adm-btn adm-btn-ghost adm-btn-sm">Search</button>
    <% if (search || category) { %><a href="/admin/blogs" class="adm-btn adm-btn-ghost adm-btn-sm">Clear</a><% } %>
  </div>
</form>

<div class="adm-card">
  <table class="adm-table">
    <thead>
      <tr>
        <th style="width:42%">Title</th>
        <th>Category</th>
        <th>Status</th>
        <th>Views</th>
        <th>Read Time</th>
        <th>Created</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% blogs.forEach(b => { %>
      <tr>
        <td>
          <a href="/admin/blogs/<%= b._id %>/edit" style="font-weight:600;display:block;max-width:380px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= b.title %></a>
          <a href="/blog/<%= b.slug %>" target="_blank" style="font-size:11px;color:var(--adm-muted)">View live ↗</a>
        </td>
        <td><span class="badge badge-blue" style="font-size:10px;text-transform:capitalize"><%= b.category.replace(/-/g,' ') %></span></td>
        <td>
          <form action="/admin/blogs/<%= b._id %>/toggle" method="POST" style="display:inline">
            <button type="submit" class="badge <%= b.published ? 'badge-green' : 'badge-amber' %>" style="border:none;cursor:pointer" title="Click to toggle">
              <%= b.published ? '● Live' : '○ Draft' %>
            </button>
          </form>
        </td>
        <td style="color:var(--adm-muted);font-size:13px"><%= b.views %></td>
        <td style="color:var(--adm-muted);font-size:13px"><%= b.readTime %>m</td>
        <td style="color:var(--adm-muted);font-size:12px;white-space:nowrap"><%= new Date(b.createdAt).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'2-digit'}) %></td>
        <td style="text-align:right;white-space:nowrap">
          <a href="/admin/blogs/<%= b._id %>/edit" class="adm-btn adm-btn-ghost adm-btn-sm">Edit</a>
          <form action="/admin/blogs/<%= b._id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this post permanently?')">
            <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Del</button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (blogs.length === 0) { %>
      <tr><td colspan="7" style="text-align:center;color:var(--adm-muted);padding:40px">
        No posts found. <a href="/admin/blogs/new" style="color:var(--adm-blue)">Create one</a> or <form action="/admin/bot/generate" method="POST" style="display:inline"><button type="submit" style="color:var(--adm-blue);background:none;border:none;cursor:pointer;font-size:inherit">run the AI bot</button></form>.
      </td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="adm-pagination">
  <% if (page > 1) { %><a href="/admin/blogs?page=<%= page-1 %>&category=<%= category %>&search=<%= search %>" class="adm-page-btn">‹</a><% } %>
  <% for(let i=1;i<=totalPages;i++) { %>
  <a href="/admin/blogs?page=<%= i %>&category=<%= category %>&search=<%= search %>" class="adm-page-btn <%= i===page?'active':'' %>"><%= i %></a>
  <% } %>
  <% if (page < totalPages) { %><a href="/admin/blogs?page=<%= page+1 %>&category=<%= category %>&search=<%= search %>" class="adm-page-btn">›</a><% } %>
</div>
<% } %>
