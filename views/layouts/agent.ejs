<!DOCTYPE html>
<html lang="<%= lang === 'id' ? 'id' : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'IDEA Agent' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css?v=sv-13">
  <link rel="stylesheet" href="/css/agent.css?v=sv-12">
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>', { anonymize_ip: true });
  </script>
  <% } %>
</head>
<body class="agent-body">
  <%- body %>
  <script>window.AGENT_LANG = '<%= lang %>';</script>
  <script src="/js/agent.js?v=sv-26"></script>
</body>
</html>
