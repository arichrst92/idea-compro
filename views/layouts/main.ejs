<!DOCTYPE html>
<html lang="<%= lang === 'id' ? 'id' : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <% if (typeof gscVerification !== 'undefined' && gscVerification) { %>
  <meta name="google-site-verification" content="<%= gscVerification %>">
  <% } %>

  <!-- Canonical & Hreflang -->
  <%
    const path = (typeof currentPath !== 'undefined' && currentPath) ? currentPath : '/';
    const canonicalUrl = siteUrl + path;
  %>
  <link rel="canonical" href="<%= canonicalUrl %>">
  <link rel="alternate" hreflang="en" href="<%= canonicalUrl %><%= path.includes('?') ? '&' : '?' %>lang=en">
  <link rel="alternate" hreflang="id" href="<%= canonicalUrl %><%= path.includes('?') ? '&' : '?' %>lang=id">
  <link rel="alternate" hreflang="x-default" href="<%= canonicalUrl %>">

  <!-- OG / Social Meta -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <meta property="og:image" content="<%= siteUrl %><%= typeof ogImage !== 'undefined' ? ogImage : '/images/og-default.jpg' %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="IDEA Asia">
  <meta property="og:locale" content="<%= lang === 'id' ? 'id_ID' : 'en_US' %>">
  <meta property="og:locale:alternate" content="<%= lang === 'id' ? 'en_US' : 'id_ID' %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %>">
  <meta name="twitter:description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <meta name="twitter:image" content="<%= siteUrl %><%= typeof ogImage !== 'undefined' ? ogImage : '/images/og-default.jpg' %>">

  <!-- Fonts: Inter (variable) — single family, SV minimalism -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/api/sitemap.xml">

  <!-- Google Analytics -->
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>', { anonymize_ip: true });
  </script>
  <% } %>

  <link rel="icon" type="image/png" sizes="64x64" href="/images/favicon-64.png?v=1774617083">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png?v=1774617083">
  <link rel="shortcut icon" type="image/png" href="/images/favicon-32.png?v=1774617083">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=1774617083">
  <link rel="stylesheet" href="/css/main.css?v=sv-8">

  <!-- JSON-LD: Organization + WebSite (site-wide) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "<%= siteUrl %>#organization",
        "name": "IDEA — Integrated Digital Ecosystem Asia",
        "alternateName": "PT Solusi Inovasi Bangsa",
        "url": "<%= siteUrl %>",
        "logo": "<%= siteUrl %>/images/logo-idea.png",
        "description": "Enterprise IT Consulting, Outsourcing, Cloud Infrastructure, Security, and Squad-Based Delivery across Southeast Asia.",
        "foundingDate": "2019",
        "email": "info@ide.asia",
        "telephone": "+62-818-0580-7807",
        "sameAs": [
          "https://www.linkedin.com/company/ideasia",
          "https://www.ide.asia"
        ],
        "address": [
          {
            "@type": "PostalAddress",
            "streetAddress": "Graha Binakarsa 7th Floor, Jl. H.R. Rasuna Said Kav C18",
            "addressLocality": "South Jakarta",
            "addressRegion": "DKI Jakarta",
            "postalCode": "12940",
            "addressCountry": "ID"
          },
          {
            "@type": "PostalAddress",
            "streetAddress": "Jl. Komp. Luxor No.5 Kav. 11",
            "addressLocality": "Bandung",
            "addressCountry": "ID"
          },
          {
            "@type": "PostalAddress",
            "streetAddress": "3rd Floor, Tan Hong Ha Complex, 317 Truong Chinh Street, Thanh Xuan District",
            "addressLocality": "Hanoi",
            "addressCountry": "VN"
          },
          {
            "@type": "PostalAddress",
            "streetAddress": "67 Sanctuary Drive, Beaumont Hills",
            "addressLocality": "Sydney",
            "addressRegion": "NSW",
            "postalCode": "2155",
            "addressCountry": "AU"
          }
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+62-818-0580-7807",
          "contactType": "sales",
          "email": "info@ide.asia",
          "availableLanguage": ["en", "id"]
        },
        "hasCredential": [
          { "@type": "EducationalOccupationalCredential", "name": "ISO 9001:2015" },
          { "@type": "EducationalOccupationalCredential", "name": "ISO 27001:2013" }
        ]
      },
      {
        "@type": "WebSite",
        "@id": "<%= siteUrl %>#website",
        "url": "<%= siteUrl %>",
        "name": "<%= siteName %>",
        "publisher": { "@id": "<%= siteUrl %>#organization" },
        "inLanguage": ["en", "id"],
        "potentialAction": {
          "@type": "SearchAction",
          "target": "<%= siteUrl %>/blog?search={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>

  <%- typeof styles !== "undefined" ? styles : "" %>
  <%- typeof jsonLd !== "undefined" ? jsonLd : "" %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/main.js?v=sv-2"></script>
  <%- typeof scripts !== "undefined" ? scripts : "" %>
</body>
</html>
