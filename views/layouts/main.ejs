<!DOCTYPE html>
<html lang="<%= lang === 'id' ? 'id' : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  
  <!-- OG / Social Meta -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <meta property="og:image" content="<%= siteUrl %><%= typeof ogImage !== 'undefined' ? ogImage : '/images/og-default.jpg' %>">
  <meta property="og:url" content="<%= siteUrl %><%= typeof currentPath !== 'undefined' ? currentPath : '' %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="IDEA Asia">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'IDEAsia - PT Solusi Inovasi Bangsa' %>">
  <meta name="twitter:description" content="<%= typeof description !== 'undefined' ? description : '' %>">
  <meta name="twitter:image" content="<%= siteUrl %><%= typeof ogImage !== 'undefined' ? ogImage : '/images/og-default.jpg' %>">
  
  <!-- Canonical -->
  <link rel="canonical" href="<%= siteUrl %>">
  
  <!-- Favicon -->
  
  
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  
  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="/api/sitemap.xml">

  <!-- Google Analytics -->
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>', { anonymize_ip: true });
  </script>
  <% } %>
  
  <link rel="icon" type="image/png" sizes="64x64" href="/images/favicon-64.png?v=1774617083">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png?v=1774617083">
  <link rel="shortcut icon" type="image/png" href="/images/favicon-32.png?v=1774617083">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=1774617083">
  <link rel="stylesheet" href="/css/main.css">
  <%- typeof styles !== "undefined" ? styles : "" %>
</head>
<body>
  <%- include('../partials/nav') %>
  
  <main>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>
  <%- typeof scripts !== "undefined" ? scripts : "" %>
</body>
</html>
