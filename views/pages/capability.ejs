const isId = lang === 'id';
%>

<!-- HERO -->
<section class="page-hero">
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= isId ? 'Kapabilitas' : 'Capability' %></div>
    <h1><%= isId ? 'Stack & Talenta yang Kami Bawa ke Setiap Engagement' : 'The Stack & Talent We Bring to Every Engagement' %></h1>
    <p><%= isId ? 'Daftar lengkap teknologi yang kami operasikan di seluruh praktik development, infrastructure, dan security — plus seluruh peran IT yang dapat di-outsource melalui kami.' : 'A complete inventory of the technologies we operate across development, infrastructure, and security — plus every IT role we deliver as outsourced talent.' %></p>
  </div>
</section>

<!-- TECH STACK SECTION -->
<section class="section">
  <div class="container">

    <% Object.entries(techStack).forEach(([key, pillar], idx) => { %>
    <div class="capability-pillar reveal">
      <div class="capability-pillar-head">
        <div class="capability-pillar-num">0<%= idx + 1 %></div>
        <div>
          <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= isId ? pillar.titleId : pillar.titleEn %></div>
          <h2 class="capability-pillar-title"><%= isId ? pillar.titleId : pillar.titleEn %></h2>
          <p class="capability-pillar-desc"><%= isId ? pillar.descId : pillar.descEn %></p>
        </div>
      </div>

      <div class="capability-groups">
        <% pillar.groups.forEach(group => { %>
        <div class="capability-group">
          <h3 class="capability-group-label"><%= isId ? group.labelId : group.labelEn %></h3>
          <div class="tech-grid">
            <% group.items.forEach(item => { %>
            <div class="tech-chip" title="<%= item.name %>">
              <% if (item.slug) { %>
              <img class="tech-chip-logo"
                   src="https://cdn.simpleicons.org/<%= item.slug %>/0A0F1C"
                   alt="<%= item.name %>"
                   loading="lazy"
                   width="22" height="22">
              <% } else { %>
              <span class="tech-chip-badge">✓</span>
              <% } %>
              <span class="tech-chip-label"><%= item.name %></span>
            </div>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>

  </div>
</section>

<!-- ROLES SECTION -->
<section class="section-alt">
  <div class="container">
    <div class="section-head-center reveal">
      <div class="section-eyebrow section-eyebrow-center"><span class="section-eyebrow-dot"></span><%= isId ? 'Talenta yang Kami Sediakan' : 'Talent We Provide' %></div>
      <h2 class="section-title"><%= isId ? 'Setiap Peran IT yang Bisa Anda Outsource' : 'Every IT Role You Can Outsource' %></h2>
      <p class="section-lede"><%= isId ? 'Tim pre-vetted di seluruh disiplin engineering, infrastructure, security, data, dan delivery — siap embed di squad Anda dalam 5–7 hari.' : 'Pre-vetted talent across engineering, infrastructure, security, data, and delivery — ready to embed in your squad within 5–7 days.' %></p>
    </div>

    <div class="roles-stack">
      <% roleCategories.forEach((cat, ci) => { %>
      <div class="role-category reveal">
        <div class="role-category-head">
          <div class="role-category-num">0<%= ci + 1 %></div>
          <h3 class="role-category-title"><%= isId ? cat.titleId : cat.titleEn %></h3>
        </div>
        <div class="role-grid">
          <% cat.roles.forEach(role => { %>
          <article class="role-card">
            <h4 class="role-card-title"><%= isId ? role.titleId : role.titleEn %></h4>
            <p class="role-card-desc"><%= isId ? role.descId : role.descEn %></p>
          </article>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <h2><%= isId ? 'Butuh Tim yang Sudah Tahu Stack Anda?' : 'Need a Team That Already Knows Your Stack?' %></h2>
      <p><%= isId ? 'Kirim role yang Anda butuhkan — kami shortlist dalam 5–7 hari kerja dari talent pool internal yang sudah pre-vetted.' : 'Send us the role you need — we shortlist within 5–7 business days from our pre-vetted internal pool.' %></p>
      <div class="cta-btns">
        <a href="/contact" class="btn btn-primary btn-large"><%= isId ? 'Diskusikan Kebutuhan' : 'Discuss Your Needs' %></a>
        <a href="/services/it-hiring" class="btn btn-outline btn-large"><%= isId ? 'Layanan Hiring' : 'Hiring Service' %></a>
      </div>
    </div>
  </div>
</section>
