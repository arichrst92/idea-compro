<div style="background:var(--black);min-height:100vh">
  <div class="blog-detail">
    <nav style="font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:32px;display:flex;gap:8px;align-items:center;padding-top:20px">
      <a href="/" style="color:rgba(255,255,255,0.4)">Home</a>
      <span>›</span>
      <a href="/blog" style="color:rgba(255,255,255,0.4)">Blog</a>
      <span>›</span>
      <span style="color:rgba(255,255,255,0.6)"><%= blog.category.replace(/-/g," ") %></span>
    </nav>

    <div class="blog-card-cat" style="margin-bottom:20px"><%= blog.category.replace(/-/g," ") %></div>

    <h1 style="font-family:var(--font-display);font-size:clamp(28px,4vw,48px);font-weight:500;line-height:1.15;letter-spacing:-0.02em;color:var(--white);margin-bottom:24px">
      <% if(lang==="id" && blog.titleId){ %><%= blog.titleId %><% } else { %><%= blog.title %><% } %>
    </h1>

    <div class="blog-meta">
      <span>By <%= blog.author %></span>
      <span style="color:rgba(255,255,255,0.2)">|</span>
      <span><%= new Date(blog.createdAt).toLocaleDateString(lang==="id"?"id-ID":"en-US",{year:"numeric",month:"long",day:"numeric"}) %></span>
      <span style="color:rgba(255,255,255,0.2)">|</span>
      <span><%= blog.readTime %> min read</span>
      <span style="color:rgba(255,255,255,0.2)">|</span>
      <span><%= blog.views %> views</span>
    </div>

    <% if(blog.contentId){ %>
    <div class="lang-toggle" id="langToggle">
      <button data-lang="en" class="<%= lang==="id" ? "" : "active" %>">🇺🇸 English</button>
      <button data-lang="id" class="<%= lang==="id" ? "active" : "" %>">🇮🇩 Indonesia</button>
    </div>
    <% } %>

    <div style="height:1px;background:rgba(255,255,255,0.08);margin-bottom:40px"></div>

    <div class="blog-body content-en" style="<%= lang==="id" && blog.contentId ? "display:none" : "" %>">
      <%- blog.content %>
    </div>

    <% if(blog.contentId){ %>
    <div class="blog-body content-id" style="<%= lang!=="id" ? "display:none" : "" %>">
      <%- blog.contentId %>
    </div>
    <% } %>

    <% if(blog.tags && blog.tags.length){ %>
    <div style="margin-top:48px;padding-top:32px;border-top:1px solid rgba(255,255,255,0.08)">
      <p style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:12px">Tags</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <% blog.tags.forEach(function(tag){ %>
        <span style="padding:6px 14px;background:rgba(255,255,255,0.06);border-radius:100px;font-size:12px;color:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.1)"><%= tag %></span>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div style="margin-top:40px;padding:24px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;gap:16px;flex-wrap:wrap">
      <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.7)"><%= lang==="id" ? "Bagikan:" : "Share:" %></span>
      <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(siteUrl+'/blog/'+blog.slug) %>" target="_blank" rel="noopener" style="padding:8px 18px;border-radius:4px;border:1px solid rgba(255,255,255,0.2);font-size:12px;color:rgba(255,255,255,0.7)">LinkedIn</a>
      <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(blog.title) %>&url=<%= encodeURIComponent(siteUrl+'/blog/'+blog.slug) %>" target="_blank" rel="noopener" style="padding:8px 18px;border-radius:4px;border:1px solid rgba(255,255,255,0.2);font-size:12px;color:rgba(255,255,255,0.7)">Twitter/X</a>
    </div>
  </div>

  <% if(related && related.length > 0){ %>
  <div style="background:var(--black2);padding:60px 0;border-top:1px solid rgba(255,255,255,0.06)">
    <div class="container">
      <h3 style="font-family:var(--font-display);font-size:22px;font-weight:500;margin-bottom:32px;color:var(--white)"><%= lang==="id" ? "Artikel Terkait" : "Related Articles" %></h3>
      <div class="blog-preview-grid">
        <% related.forEach(function(r){ %>
        <article class="blog-card">
          <div class="blog-card-cat"><%= (r.category||"").replace(/-/g," ") %></div>
          <h3><a href="/blog/<%= r.slug %>"><%= lang==="id" && r.titleId ? r.titleId : r.title %></a></h3>
          <p><%= ((lang==="id" && r.excerptId ? r.excerptId : r.excerpt)||"").substring(0,100) %>...</p>
          <div class="blog-card-meta">
            <span><%= new Date(r.createdAt).toLocaleDateString(lang==="id"?"id-ID":"en-US",{year:"numeric",month:"short",day:"numeric"}) %></span>
            <span><%= r.readTime %> min read</span>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>
</div>