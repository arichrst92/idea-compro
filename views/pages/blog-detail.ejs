<div class="blog-detail-wrap">
  <div class="blog-detail">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/blog">Blog</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current"><%= blog.category.replace(/-/g," ") %></span>
    </nav>

    <div class="blog-card-cat"><%= blog.category.replace(/-/g," ") %></div>

    <h1>
      <% if(lang==="id" && blog.titleId){ %><%= blog.titleId %><% } else { %><%= blog.title %><% } %>
    </h1>

    <div class="blog-meta">
      <span>By <%= blog.author %></span>
      <span class="blog-meta-sep">|</span>
      <span><%= new Date(blog.createdAt).toLocaleDateString(lang==="id"?"id-ID":"en-US",{year:"numeric",month:"long",day:"numeric"}) %></span>
      <span class="blog-meta-sep">|</span>
      <span><%= blog.readTime %> min read</span>
      <span class="blog-meta-sep">|</span>
      <span><%= blog.views %> views</span>
    </div>

    <% if(blog.contentId){ %>
    <div class="lang-toggle" id="langToggle">
      <button data-lang="en" class="<%= lang==="id" ? "" : "active" %>">🇺🇸 English</button>
      <button data-lang="id" class="<%= lang==="id" ? "active" : "" %>">🇮🇩 Indonesia</button>
    </div>
    <% } %>

    <div class="blog-divider"></div>

    <div class="blog-body content-en" <% if(lang==="id" && blog.contentId){ %>style="display:none"<% } %>>
      <%- blog.content %>
    </div>

    <% if(blog.contentId){ %>
    <div class="blog-body content-id" <% if(lang!=="id"){ %>style="display:none"<% } %>>
      <%- blog.contentId %>
    </div>
    <% } %>

    <% if(blog.tags && blog.tags.length){ %>
    <div class="blog-tags-section">
      <p class="label">Tags</p>
      <div class="tag-list">
        <% blog.tags.forEach(function(tag){ %>
        <span class="tag-pill"><%= tag %></span>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="share-bar">
      <span class="label"><%= lang==="id" ? "Bagikan:" : "Share:" %></span>
      <a class="share-btn" href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(siteUrl+'/blog/'+blog.slug) %>" target="_blank" rel="noopener">LinkedIn</a>
      <a class="share-btn" href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(blog.title) %>&url=<%= encodeURIComponent(siteUrl+'/blog/'+blog.slug) %>" target="_blank" rel="noopener">Twitter/X</a>
    </div>
  </div>

  <% if(related && related.length > 0){ %>
  <div class="related-section">
    <div class="container">
      <h3><%= lang==="id" ? "Artikel Terkait" : "Related Articles" %></h3>
      <div class="blog-preview-grid">
        <% related.forEach(function(r){ %>
        <article class="blog-card">
          <div class="blog-card-cat"><%= (r.category||"").replace(/-/g," ") %></div>
          <h3><a href="/blog/<%= r.slug %>"><%= lang==="id" && r.titleId ? r.titleId : r.title %></a></h3>
          <p><%= ((lang==="id" && r.excerptId ? r.excerptId : r.excerpt)||"").substring(0,100) %>...</p>
          <div class="blog-card-meta">
            <span><%= new Date(r.createdAt).toLocaleDateString(lang==="id"?"id-ID":"en-US",{year:"numeric",month:"short",day:"numeric"}) %></span>
            <span><%= r.readTime %> min read</span>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>
</div>
