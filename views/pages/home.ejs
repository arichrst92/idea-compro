      <a href="/blog" class="btn btn-outline"><%= lang === 'id' ? 'Semua Artikel' : 'All Articles' %> →</a>
    </div>
    <div class="blog-preview-grid">
      <% recentBlogs.forEach((blog, i) => { %>
      <article class="blog-card reveal reveal-delay-<%= i %>">
        <span class="blog-card-cat"><%= blog.category.replace(/-/g,' ') %></span>
        <h3><a href="/blog/<%= blog.slug %>"><%= lang === 'id' && blog.titleId ? blog.titleId : blog.title %></a></h3>
        <p><%= (lang === 'id' && blog.excerptId ? blog.excerptId : blog.excerpt).substring(0,110) %>...</p>
        <div class="blog-card-meta">
          <span><%= new Date(blog.createdAt).toLocaleDateString(lang==='id'?'id-ID':'en-US',{year:'numeric',month:'short',day:'numeric'}) %></span>
          <span><%= blog.readTime %> min read</span>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

