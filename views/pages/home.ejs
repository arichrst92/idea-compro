<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-line"></div>
  <div class="hero-line-2"></div>
  <div class="hero-glow"></div>

  <!-- High-tech animated canvas background -->
  <canvas id="heroCanvas" style="position:absolute;inset:0;width:100%;height:100%;opacity:0.6;pointer-events:none;z-index:0"></canvas>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-line"></span>
      <%= lang === 'id' ? 'Mitra Teknologi Enterprise' : 'Enterprise Technology Partner' %>
    </div>
    <h1 class="hero-title">
      <%= lang === 'id' ? 'Integrated' : 'Integrated' %><br>
      <em>Digital</em><br>
      <%= lang === 'id' ? 'Ecosystem' : 'Ecosystem' %>
    </h1>
    <div class="hero-bottom">
      <div>
        <p class="hero-desc">
          <% if(lang==='id'){ %>Ceritakan Tantangan IT Terbesar Anda.<br>Kami Akan Tunjukkan Cara Mengatasinya.<% } else { %>Tell Us Your Biggest IT Challenge.<br>We'll Tell You How to Solve It.<% } %>
        </p>
        <p class="hero-sub">
          <%= lang==='id' ? 'Jadwalkan sesi strategi 30 menit dengan konsultan IDEA — tanpa sales pitch, hanya perspektif ahli untuk situasi spesifik Anda.' : 'Book a 30-minute strategy session with an IDEA consultant — no sales pitch, just expert perspective on your specific situation.' %>
        </p>
      </div>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-large"><%= lang==='id' ? 'Jadwalkan Sesi Strategi 30 Menit' : 'Book a 30-Min Strategy Call' %></a>
        <a href="/services" class="btn btn-outline btn-large"><%= lang==='id' ? 'Lihat Layanan' : 'Our Services' %></a>
      </div>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="hero-scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-track">
    <div class="ticker-item"><span class="ticker-dot"></span>IT Consulting</div>
    <div class="ticker-item"><span class="ticker-dot"></span>IT Outsourcing</div>
    <div class="ticker-item"><span class="ticker-dot"></span>Cloud Infrastructure</div>
    <div class="ticker-item"><span class="ticker-dot"></span>IT Security</div>
    <div class="ticker-item"><span class="ticker-dot"></span>IT Hiring</div>
    <div class="ticker-item"><span class="ticker-dot"></span>Squad Based Delivery</div>
    <div class="ticker-item"><span class="ticker-dot"></span>Digital Transformation</div>
    <div class="ticker-item"><span class="ticker-dot"></span>Enterprise Technology</div>
  </div>
</div>

