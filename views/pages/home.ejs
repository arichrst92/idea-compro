<!-- ════════════════════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════════════════════ -->
<section class="hero" id="hero">
  <div class="hero-line"></div>
  <div class="hero-line-2"></div>
  <div class="hero-glow"></div>
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-line"></span>
      <%= lang === 'id' ? 'Mitra Teknologi Enterprise' : 'Enterprise Technology Partner' %>
    </div>
    <h1 class="hero-title">
      Integrated<br>
      <em>Digital</em><br>
      Ecosystem
    </h1>
    <div class="hero-bottom">
      <div>
        <p class="hero-desc">
          <% if(lang==='id'){ %>Ceritakan tantangan IT terbesar Anda.<br>Kami akan tunjukkan cara mengatasinya.<% } else { %>Tell us your biggest IT challenge.<br>We'll tell you how to solve it.<% } %>
        </p>
        <p class="hero-sub">
          <%= lang==='id'
            ? 'Jadwalkan sesi strategi 30 menit dengan konsultan IDE Asia — tanpa sales pitch, hanya perspektif ahli untuk situasi spesifik Anda.'
            : 'Book a 30-minute strategy session with an IDE Asia consultant — no sales pitch, just expert perspective on your specific situation.' %>
        </p>
      </div>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-large"><%= lang==='id' ? 'Jadwalkan Sesi Strategi' : 'Book a Strategy Call' %></a>
        <a href="/services" class="btn btn-ghost btn-large"><%= lang==='id' ? 'Lihat Layanan' : 'Explore Services' %> →</a>
      </div>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="hero-scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

