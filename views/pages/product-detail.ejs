<%
const isId = lang === 'id';
const catTitle = isId ? category.titleId : category.titleEn;
const useShort = isId ? product.useId  : product.useEn;
const descLong = isId ? product.descLongId : product.descLongEn;
const features = isId ? product.featuresId : product.featuresEn;
const useCases = isId ? product.useCasesId : product.useCasesEn;
const discussMsg = (isId ? 'Diskusi tentang ' : 'Discussion about ') + product.name;
%>

<!-- HERO / BREADCRUMB -->
<section class="page-hero product-detail-hero">
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <nav class="product-breadcrumb" aria-label="breadcrumb">
      <a href="/products"><%= isId ? 'Produk' : 'Products' %></a>
      <span aria-hidden="true">›</span>
      <a href="/products?cat=<%= category.id %>"><%= catTitle %></a>
      <span aria-hidden="true">›</span>
      <span class="product-breadcrumb-current"><%= product.name %></span>
    </nav>

    <div class="product-detail-hero-grid">
      <div>
        <div class="section-eyebrow">
          <span class="section-eyebrow-dot"></span>
          <%= catTitle %>
          <span class="ibm-partner-pill">IBM Certified Partner</span>
        </div>
        <h1 class="product-detail-name"><%= product.name %></h1>
        <p class="product-detail-tagline"><%= useShort %></p>

        <div class="product-detail-meta">
          <div class="pdm-item">
            <span class="pdm-label"><%= isId ? 'Model Lisensi' : 'Licensing' %></span>
            <span class="pdm-val"><%= product.tier %></span>
          </div>
          <div class="pdm-item">
            <span class="pdm-label"><%= isId ? 'Estimasi Implementasi' : 'Implementation Timeline' %></span>
            <span class="pdm-val"><%= product.timeline %></span>
          </div>
        </div>

        <div class="product-detail-cta">
          <a href="/contact?service=it-consulting&msg=<%= encodeURIComponent(discussMsg) %>" class="btn btn-primary btn-large">
            <%= isId ? 'Diskusikan dengan Tim Kami' : 'Talk to Our Team' %>
          </a>
          <a href="<%= product.url %>" target="_blank" rel="noopener" class="btn btn-outline btn-large">
            <%= isId ? 'Lihat di IBM.com' : 'View on IBM.com' %>
            <svg width="14" height="14" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:6px;vertical-align:-1px"><path d="M5 3h5v5M10 3l-6 6"/></svg>
          </a>
        </div>
      </div>

      <aside class="product-detail-vendor">
        <img src="https://cdn.simpleicons.org/ibm/0A0F1C" alt="IBM" width="48" height="48" data-fallback="IBM">
        <div class="pdv-name">IBM</div>
        <div class="pdv-tag"><%= isId ? 'Vendor resmi' : 'Official vendor' %></div>
      </aside>
    </div>
  </div>
</section>

<!-- LONG DESCRIPTION -->
<section class="product-detail-section">
  <div class="container">
    <div class="product-detail-2col">
      <div class="pd-main">
        <h2 class="pd-h2"><%= isId ? 'Tentang ' + product.name : 'About ' + product.name %></h2>
        <p class="pd-lead"><%= descLong %></p>

        <h3 class="pd-h3"><%= isId ? 'Fitur Utama' : 'Key Features' %></h3>
        <ul class="pd-feature-list">
          <% features.forEach(f => { %>
          <li>
            <svg class="pd-check" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 9.5l3.5 3.5L14.5 5.5"/></svg>
            <span><%= f %></span>
          </li>
          <% }) %>
        </ul>

        <h3 class="pd-h3"><%= isId ? 'Use Case Industri' : 'Industry Use Cases' %></h3>
        <div class="pd-usecase-grid">
          <% useCases.forEach((u, i) => { %>
          <div class="pd-usecase">
            <span class="pd-usecase-num">0<%= i + 1 %></span>
            <span><%= u %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <aside class="pd-aside">
        <div class="pd-aside-card">
          <h4 class="pd-aside-title"><%= isId ? 'Layanan IDEA Asia' : 'IDEA Asia Services' %></h4>
          <ul class="pd-aside-list">
            <li><%= isId ? 'Lisensi & sourcing langsung dari IBM' : 'Direct licensing & sourcing from IBM' %></li>
            <li><%= isId ? 'Arsitektur & deployment' : 'Architecture & deployment' %></li>
            <li><%= isId ? 'Integrasi dengan sistem existing' : 'Integration with existing systems' %></li>
            <li><%= isId ? 'Managed services & 24/7 support' : 'Managed services & 24/7 support' %></li>
            <li><%= isId ? 'Training tim internal Anda' : 'Internal team training' %></li>
          </ul>
        </div>

        <div class="pd-aside-card pd-aside-cta">
          <h4 class="pd-aside-title"><%= isId ? 'Mulai Sekarang' : 'Get Started' %></h4>
          <p class="pd-aside-desc"><%= isId
            ? 'Dapatkan konsultasi awal gratis untuk memahami fit produk dengan kebutuhan Anda.'
            : 'Get a free initial consultation to understand product fit for your needs.' %></p>
          <a href="/contact?service=it-consulting&msg=<%= encodeURIComponent(discussMsg) %>" class="btn btn-primary btn-full">
            <%= isId ? 'Jadwalkan Konsultasi' : 'Schedule a Call' %>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- RELATED PRODUCTS -->
<% if (related && related.length) { %>
<section class="product-detail-related">
  <div class="container">
    <div class="section-eyebrow">
      <span class="section-eyebrow-dot"></span>
      <%= isId ? 'Produk Terkait' : 'Related Products' %>
    </div>
    <h2 class="pd-related-title"><%= isId ? 'Eksplorasi lainnya di ' + catTitle : 'More from ' + catTitle %></h2>

    <div class="product-grid">
      <% related.forEach(r => { %>
      <article class="product-card">
        <a href="/products/<%= r.slug %>" class="product-card-titlelink" aria-label="<%= r.name %>"></a>
        <div class="product-card-top">
          <img class="product-card-vendor" src="https://cdn.simpleicons.org/ibm/0A0F1C" alt="IBM" loading="lazy" data-fallback="IBM" width="22" height="22">
          <span class="product-card-cat-tag"><%= catTitle %></span>
        </div>
        <h3 class="product-card-name"><%= r.name %></h3>
        <p class="product-card-use"><%= isId ? r.useId : r.useEn %></p>
        <div class="product-card-footer">
          <a href="/products/<%= r.slug %>" class="product-card-link">
            <%= isId ? 'Pelajari' : 'Learn more' %>
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5h7M7 3.5l3 3-3 3"/></svg>
          </a>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <h2><%= isId ? 'Implementasikan ' + product.name + ' bersama IDEA Asia' : 'Implement ' + product.name + ' with IDEA Asia' %></h2>
      <p><%= isId
        ? 'Tim kami berpengalaman menerapkan produk IBM untuk perbankan, asuransi, telekomunikasi, dan pemerintahan di Asia Tenggara.'
        : 'Our team has deep experience deploying IBM products for banking, insurance, telco, and government across Southeast Asia.' %></p>
      <div class="cta-btns">
        <a href="/contact?service=it-consulting&msg=<%= encodeURIComponent(discussMsg) %>" class="btn btn-primary btn-large">
          <%= isId ? 'Hubungi Tim Kami' : 'Talk to Our Team' %>
        </a>
        <a href="/products" class="btn btn-outline btn-large">
          <%= isId ? 'Kembali ke Katalog' : 'Back to Catalog' %>
        </a>
      </div>
    </div>
  </div>
</section>
