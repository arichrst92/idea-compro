<%
// ──────────────────────────────────────────────────────────────────
// IBM Product Catalog — data sourced from src/data/ibm-products.js
// `categories` & `products` are injected by src/routes/products.js
// ──────────────────────────────────────────────────────────────────
const isId = lang === 'id';
const totalProducts = products.length;

// Group products by category for rendering
const grouped = categories.map(cat => ({
  ...cat,
  items: products.filter(p => p.categoryId === cat.id),
}));
%>

<!-- HERO -->
<section class="page-hero">
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <div class="section-eyebrow">
      <span class="section-eyebrow-dot"></span>
      <%= isId ? 'Produk' : 'Products' %>
      <span class="ibm-partner-pill">IBM Certified Partner</span>
    </div>
    <h1><%= isId ? 'Katalog Produk IBM' : 'IBM Product Catalog' %></h1>
    <p>
      <%= isId
        ? totalProducts + '+ produk IBM yang kami implementasikan, integrasikan, dan support untuk enterprise di Asia Tenggara. Mulai dari watsonx hingga mainframe Z.'
        : totalProducts + '+ IBM products we implement, integrate, and support for enterprises across Southeast Asia. From watsonx to Z mainframes.' %>
    </p>
  </div>
</section>

<!-- CATEGORY FILTER -->
<div class="products-filter-bar">
  <div class="container">
    <div class="products-filters" id="productsFilters">
      <button class="filter-btn active" data-cat="all"><%= isId ? 'Semua' : 'All' %></button>
      <% categories.forEach(cat => { %>
      <button class="filter-btn" data-cat="<%= cat.id %>"><%= isId ? cat.titleId : cat.titleEn %></button>
      <% }) %>
    </div>
  </div>
</div>

<!-- CATALOG -->
<section class="products-wrap">
  <div class="container">

    <% grouped.forEach((cat, ci) => { %>
    <section class="product-category" data-cat="<%= cat.id %>">
      <div class="product-category-head">
        <div class="product-category-num">0<%= ci + 1 %></div>
        <div>
          <h2 class="product-category-title"><%= isId ? cat.titleId : cat.titleEn %></h2>
          <p class="product-category-desc"><%= isId ? cat.descId : cat.descEn %></p>
        </div>
      </div>

      <div class="product-grid">
        <% cat.items.forEach(p => { %>
        <article class="product-card">
          <a href="/products/<%= p.slug %>" class="product-card-titlelink" aria-label="<%= p.name %>"></a>
          <div class="product-card-top">
            <span class="vendor-mark" aria-label="IBM">IBM</span>
            <span class="product-card-cat-tag"><%= isId ? cat.titleId : cat.titleEn %></span>
          </div>
          <h3 class="product-card-name"><%= p.name %></h3>
          <p class="product-card-use"><%= isId ? p.useId : p.useEn %></p>
          <div class="product-card-footer">
            <a href="/products/<%= p.slug %>" class="product-card-link">
              <%= isId ? 'Pelajari' : 'Learn more' %>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5h7M7 3.5l3 3-3 3"/></svg>
            </a>
            <a href="/contact?service=it-consulting&msg=<%= encodeURIComponent((isId ? 'Saya tertarik dengan ' : 'I am interested in ') + p.name) %>" class="product-card-cta">
              <%= isId ? 'Diskusikan' : 'Discuss' %>
            </a>
          </div>
        </article>
        <% }) %>
      </div>
    </section>
    <% }) %>

  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <h2><%= isId ? 'Butuh Bantuan Implementasi atau Lisensi?' : 'Need Help With Implementation or Licensing?' %></h2>
      <p><%= isId
        ? 'Sebagai partner resmi IBM di Asia Tenggara, kami dapat membantu Anda mulai dari sourcing lisensi, arsitektur, deployment, hingga managed services.'
        : 'As an official IBM partner in Southeast Asia, we can help you from licensing and architecture to deployment and managed services.' %></p>
      <div class="cta-btns">
        <a href="/contact" class="btn btn-primary btn-large"><%= isId ? 'Hubungi Tim Kami' : 'Talk to Our Team' %></a>
        <a href="/capability" class="btn btn-outline btn-large"><%= isId ? 'Lihat Kapabilitas' : 'See Capabilities' %></a>
      </div>
    </div>
  </div>
</section>

<script>
  // Category filter — show/hide product-category sections
  (function(){
    const filterBar = document.getElementById('productsFilters');
    if (!filterBar) return;
    const sections = document.querySelectorAll('.product-category');
    filterBar.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      const cat = btn.dataset.cat;
      filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b === btn));
      sections.forEach(s => {
        if (cat === 'all' || s.dataset.cat === cat) s.style.display = '';
        else s.style.display = 'none';
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>
