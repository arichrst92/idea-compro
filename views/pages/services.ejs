<section class="page-hero">
  <div class="container">
    <p class="section-eyebrow"><%= lang === 'id' ? 'Apa yang Kami Lakukan' : 'What We Do' %></p>
    <h1 class="section-title"><%= lang === 'id' ? 'Layanan Kami' : 'Our Services' %></h1>
    <p style="color:var(--gray-600);margin-top:12px;font-size:17px;max-width:600px">
      <%= lang === 'id' ? 'Solusi teknologi enterprise dari konsultasi strategis hingga eksekusi teknis yang terukur.' : 'Enterprise technology solutions from strategic consulting to measurable technical execution.' %>
    </p>
  </div>
</section>

<div style="background:var(--white)">
  <div class="container">
    <div class="services-page-grid">
      <% services.forEach((s, i) => { %>
      <div class="service-card reveal reveal-delay-<%= (i % 3) + 1 %>">
        <div class="service-card-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <% if (s.slug === 'it-consulting') { %>
            <polyline points="4,20 10,14 15,18 22,10"/><circle cx="22" cy="8" r="2" fill="currentColor" opacity="0.3"/>
            <% } else if (s.slug === 'it-outsourcing') { %>
            <circle cx="14" cy="14" r="9" opacity="0.3"/><path d="M8 14a6 6 0 0 1 6-6"/><path d="M20 14a6 6 0 0 1-6 6"/><path d="M18 11l2 3 3-1"/><path d="M10 17l-2-3-3 1"/>
            <% } else if (s.slug === 'it-hiring') { %>
            <circle cx="14" cy="10" r="4"/><path d="M5.5 24c0-4.7 3.8-8.5 8.5-8.5s8.5 3.8 8.5 8.5"/><path d="M21 7l1.5 1.5 3-3"/>
            <% } else if (s.slug === 'cloud-infrastructure') { %>
            <path d="M7 20a6 6 0 0 1 0-12h.4A7.5 7.5 0 0 1 21 15a4.5 4.5 0 0 1-1.5 8.7"/><path d="M14 16v7"/><path d="M11 20l3 3 3-3"/>
            <% } else if (s.slug === 'it-security') { %>
            <path d="M14 4l-9 3.8v7.7c0 5.2 4 10 9 11.5 5-1.5 9-6.3 9-11.5V7.8L14 4z"/><path d="M10.5 14l2.5 2.5 5.5-5.5"/>
            <% } else { %>
            <circle cx="9" cy="10" r="3"/><circle cx="19" cy="10" r="3"/><circle cx="14" cy="7" r="3" fill="currentColor" opacity="0.2"/><path d="M3 23c0-3.3 2.7-6 6-6"/><path d="M19 17c3.3 0 6 2.7 6 6"/><path d="M10 23c0-2.2 1.8-4 4-4s4 1.8 4 4"/>
            <% } %>
          </svg>
        </div>
        <div class="service-num" style="font-family:var(--font-display);font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--blue);margin-bottom:12px">0<%= i+1 %></div>
        <h3 class="service-card-title"><%= lang === 'id' ? s.titleId : s.titleEn %></h3>
        <p><%= lang === 'id' ? s.descId : s.descEn %></p>
        <ul class="service-card-features">
          <% const features = lang === 'id' ? s.featuresId : s.features; %>
          <% features.forEach(f => { %><li><%= f %></li><% }) %>
        </ul>
        <a href="/services/<%= s.slug %>" class="service-card-link">
          <%= lang === 'id' ? 'Pelajari Lebih Lanjut' : 'Learn More' %>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Bottom CTA -->
<section class="cta-section" style="padding-top:0">
  <div class="container">
    <div class="cta-inner">
      <h2><%= lang === 'id' ? 'Tidak Yakin Layanan Mana yang Tepat?' : "Not Sure Which Service You Need?" %></h2>
      <p><%= lang === 'id' ? 'Tim konsultan kami siap membantu menganalisis kebutuhan bisnis Anda dan merekomendasikan solusi yang paling tepat.' : 'Our consultants are ready to analyze your business needs and recommend the most suitable solution.' %></p>
      <div class="cta-btns">
        <a href="/contact" class="btn btn-primary btn-large"><%= lang === 'id' ? 'Jadwalkan Konsultasi' : 'Schedule a Consultation' %></a>
      </div>
    </div>
  </div>
</section>
