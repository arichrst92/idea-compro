<!-- ABOUT HERO -->
<section class="about-hero">
  <div class="container">
    <div class="about-hero-grid">
      <div>
        <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= lang === 'id' ? 'Tentang Kami' : 'About Us' %></div>
        <h1>
          <% if(lang==='id'){ %>Ekosistem Digital<br><span style="color:var(--gray-700)">yang Menggerakkan Asia</span>
          <% } else { %>The Digital Ecosystem<br><span style="color:var(--gray-700)">Powering Asia</span><% } %>
        </h1>
        <p>
          <%= lang === 'id'
            ? 'PT Solusi Inovasi Bangsa (IDEA — Integrated Digital Ecosystem Asia) didirikan dengan visi menjadi perusahaan IT terkemuka di kawasan Asia-Pasifik, mampu melayani korporasi global dengan keunggulan dalam penyampaian layanan.'
            : 'PT Solusi Inovasi Bangsa (IDEA — Integrated Digital Ecosystem Asia) was founded with the vision to become a renowned IT company in the Asia-Pacific region, capable of catering to global corporations with excellence in service delivery.' %>
        </p>
        <div style="display:flex;gap:40px;margin-top:40px">
          <div>
            <p style="font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--white);line-height:1;letter-spacing:-0.03em">12+</p>
            <p style="font-size:12px;color:var(--gray-600);margin-top:6px;letter-spacing:0.04em;text-transform:uppercase"><%= lang==='id' ? 'Tahun Pengalaman' : 'Years Experience' %></p>
          </div>
          <div>
            <p style="font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--white);line-height:1;letter-spacing:-0.03em">20+</p>
            <p style="font-size:12px;color:var(--gray-600);margin-top:6px;letter-spacing:0.04em;text-transform:uppercase"><%= lang==='id' ? 'Klien Enterprise' : 'Enterprise Clients' %></p>
          </div>
          <div>
            <p style="font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--white);line-height:1;letter-spacing:-0.03em">5</p>
            <p style="font-size:12px;color:var(--gray-600);margin-top:6px;letter-spacing:0.04em;text-transform:uppercase"><%= lang==='id' ? 'Kantor Negara' : 'Country Offices' %></p>
          </div>
        </div>
        <div style="margin-top:40px;display:flex;gap:12px">
          <a href="/contact" class="btn btn-primary"><%= lang==='id' ? 'Hubungi Kami' : 'Contact Us' %></a>
          <a href="/services" class="btn btn-outline"><%= lang==='id' ? 'Lihat Layanan' : 'Our Services' %></a>
        </div>
      </div>
      <div class="about-visual">
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(26,80,232,0.12) 0%,transparent 60%);pointer-events:none"></div>
        <div style="text-align:center;position:relative;z-index:1;padding:40px">
          <img src="/images/logo.png" alt="IDEA Asia" style="height:60px;margin:0 auto 24px;filter:brightness(0) invert(1);opacity:0.85">
          <p style="font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--gray-600);margin-bottom:8px">PT Solusi Inovasi Bangsa</p>
          <p style="font-size:12px;color:var(--gray-700)">AHU-AH.01.09-0249721</p>
          <div style="display:flex;gap:8px;justify-content:center;margin-top:28px;flex-wrap:wrap">
            <span style="padding:6px 14px;border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:11px;color:var(--gray-600);letter-spacing:0.04em">ISO 9001:2015</span>
            <span style="padding:6px 14px;border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:11px;color:var(--gray-600);letter-spacing:0.04em">ISO 27001:2013</span>
          </div>
          <div style="margin-top:32px;display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <% ['Jakarta','Bandung','Hanoi','Sydney'].forEach(city => { %>
            <span style="padding:5px 12px;background:rgba(255,255,255,0.04);border-radius:100px;font-size:11px;color:var(--gray-600)"><%= city %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VISION & MISSION -->
<section style="padding:100px 0;background:var(--black2);border-top:1px solid rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.06)">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,0.06)">
      <!-- Vision -->
      <div style="background:var(--black2);padding:60px">
        <div class="section-eyebrow"><span class="section-eyebrow-dot"></span>Vision</div>
        <h2 style="font-family:var(--font-display);font-size:clamp(28px,3vw,40px);font-weight:800;letter-spacing:-0.02em;color:var(--white);margin-bottom:24px;line-height:1.1">
          <%= lang==='id'
            ? 'Perusahaan IT Terkemuka di Asia-Pasifik'
            : 'A Renowned IT Company in Asia-Pacific' %>
        </h2>
        <p style="font-size:16px;color:var(--gray-500);line-height:1.8">
          <%= lang==='id'
            ? 'Menjadi perusahaan IT terkemuka di kawasan Asia-Pasifik, mampu melayani korporasi global dengan keunggulan dalam penyampaian layanan.'
            : 'To become a renowned IT company in the Asia-Pacific region, capable of catering to global corporations with excellence in service delivery.' %>
        </p>
      </div>
      <!-- Mission -->
      <div style="background:var(--black);padding:60px">
        <div class="section-eyebrow"><span class="section-eyebrow-dot"></span>Mission</div>
        <h2 style="font-family:var(--font-display);font-size:clamp(28px,3vw,40px);font-weight:800;letter-spacing:-0.02em;color:var(--white);margin-bottom:28px;line-height:1.1">
          <%= lang==='id' ? 'Komitmen Kami' : 'Our Commitment' %>
        </h2>
        <ul style="display:flex;flex-direction:column;gap:0">
          <% const missions = lang==='id' ? [
            'Meningkatkan keahlian setiap karyawan di bidang IT',
            'Menjunjung integritas sebagai fondasi hubungan klien jangka panjang',
            'Memastikan penyampaian proyek dan layanan yang seamless kepada klien korporat',
            'Terus meningkatkan standar layanan untuk meringankan kekhawatiran klien',
            'Berkontribusi pada kemajuan IT di Indonesia',
            'Menumbuhkan persatuan, pemberdayaan, dan lingkungan kerja kolaboratif'
          ] : [
            'Elevating the expertise of every employee in the realm of IT',
            'Upholding integrity as paramount to enduring client relationships',
            'Ensuring the seamless delivery of projects and services to corporate clients',
            'Constantly enhancing and refining our service standards to alleviate client concerns',
            'Contributing to the advancement of IT in Indonesia',
            'Fostering unity, empowerment, and a collaborative work environment'
          ]; %>
          <% missions.forEach(m => { %>
          <li style="display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:14px;color:var(--gray-400);line-height:1.6">
            <span style="width:18px;height:1px;background:var(--blue);flex-shrink:0;margin-top:10px"></span>
            <%= m %>
          </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- P.R.I.D.E VALUES -->
<section style="padding:100px 0;background:var(--black)">
  <div class="container">
    <div style="text-align:center;margin-bottom:72px" class="reveal">
      <div class="section-eyebrow" style="justify-content:center"><span class="section-eyebrow-dot"></span><%= lang==='id' ? 'Nilai-Nilai Kami' : 'Our Values' %></div>
      <h2 class="section-title">P.R.I.D.E</h2>
      <p style="font-size:15px;color:var(--gray-600);margin-top:16px;max-width:500px;margin-left:auto;margin-right:auto">
        <%= lang==='id' ? 'Lima nilai inti yang memandu setiap keputusan dan tindakan tim IDEA.' : 'Five core values that guide every decision and action of the IDEA team.' %>
      </p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:rgba(255,255,255,0.06)">
      <% const values = [
        { letter:'P', name:'Professionalism', nameId:'Profesionalisme', desc:'We are committed to conducting every aspect of our business with a high level of professionalism, delivering the best IT services and solutions.', descId:'Kami berkomitmen menjalankan setiap aspek bisnis dengan profesionalisme tinggi, memberikan layanan dan solusi IT terbaik.' },
        { letter:'R', name:'Reliability', nameId:'Reliabilitas', desc:'Reliability is the foundation of our business. We are always dependable in delivering our projects and services, ensuring the trust of our clients.', descId:'Keandalan adalah fondasi bisnis kami. Kami selalu dapat diandalkan dalam menjalankan proyek dan layanan, menjaga kepercayaan klien.' },
        { letter:'I', name:'Innovation', nameId:'Inovasi', desc:'We encourage innovation in everything we do, seeking new and creative solutions to meet our client\'s technology needs and challenges.', descId:'Kami mendorong inovasi dalam segala hal yang kami lakukan, mencari solusi kreatif untuk memenuhi kebutuhan teknologi klien.' },
        { letter:'D', name:'Diversity', nameId:'Diversitas', desc:'We value diversity as a strength. Our workplace culture is inclusive, accepting various backgrounds, perspectives, and abilities.', descId:'Kami menghargai keberagaman sebagai kekuatan. Budaya kerja kami inklusif, menerima berbagai latar belakang dan kemampuan.' },
        { letter:'E', name:'Excellence', nameId:'Keunggulan', desc:'Excellence is our standard. We constantly strive to perfect our services, delivering outstanding results to our clients.', descId:'Keunggulan adalah standar kami. Kami terus berupaya menyempurnakan layanan dan memberikan hasil luar biasa kepada klien.' }
      ]; %>
      <% values.forEach((v,i) => { %>
      <div class="value-card reveal reveal-delay-<%= i % 3 %>" style="padding:40px 32px">
        <div style="font-family:var(--font-display);font-size:56px;font-weight:800;color:rgba(26,80,232,0.2);line-height:1;margin-bottom:20px;letter-spacing:-0.04em"><%= v.letter %></div>
        <h4 style="font-family:var(--font-display);font-size:16px;font-weight:700;color:var(--white);margin-bottom:12px"><%= lang==='id' ? v.nameId : v.name %></h4>
        <p style="font-size:13px;color:var(--gray-600);line-height:1.7"><%= lang==='id' ? v.descId : v.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- COMPANY HISTORY TIMELINE -->
<section style="padding:100px 0;background:var(--black2);border-top:1px solid rgba(255,255,255,0.06)">
  <div class="container">
    <div class="reveal" style="margin-bottom:64px">
      <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= lang==='id' ? 'Perjalanan Kami' : 'Our Journey' %></div>
      <h2 class="section-title"><% if(lang==='id'){ %>Sejarah<br><span style="color:var(--gray-700)">Perusahaan</span><% } else { %>Company<br><span style="color:var(--gray-700)">History</span><% } %></h2>
    </div>
    <div style="position:relative;padding-left:40px">
      <!-- Vertical line -->
      <div style="position:absolute;left:0;top:8px;bottom:8px;width:1px;background:rgba(255,255,255,0.06)"></div>
      <% const timeline = [
        { year:'2013', event: lang==='id' ? 'Proyek Pertama Kami' : 'Our First Project' },
        { year:'2016', event: lang==='id' ? 'Mulai Pengembangan Software' : 'Start Software Development' },
        { year:'2019', event: lang==='id' ? 'IDE.Asia Didirikan' : 'IDE.Asia Founded' },
        { year:'2022', event: lang==='id' ? 'Mulai Proyek Luar Negeri' : 'Start Overseas Project' },
        { year:'2023', event: lang==='id' ? 'Perluasan Cakupan Klien' : 'Scaling Client Coverage' },
        { year:'2024', event: lang==='id' ? 'Perluasan Cakupan Klien' : 'Scaling Client Coverage' },
        { year:'2025', event: lang==='id' ? 'Memperluas Sales Representative' : 'Expanding Sales Representative' },
      ]; %>
      <% timeline.forEach((t,i) => { %>
      <div class="reveal reveal-delay-<%= i%3 %>" style="display:flex;align-items:center;gap:32px;padding:24px 0;border-bottom:1px solid rgba(255,255,255,0.04);position:relative">
        <div style="position:absolute;left:-44px;width:10px;height:10px;border-radius:50%;background:<%= i===timeline.length-1 ? 'var(--blue)' : 'rgba(255,255,255,0.15)' %>;border:1px solid rgba(255,255,255,0.2)"></div>
        <div style="font-family:var(--font-display);font-size:28px;font-weight:800;color:<%= i===timeline.length-1 ? 'var(--white)' : 'var(--gray-800)' %>;letter-spacing:-0.02em;min-width:80px"><%= t.year %></div>
        <div style="font-size:16px;color:<%= i===timeline.length-1 ? 'var(--white)' : 'var(--gray-500)' %>"><%= t.event %></div>
        <% if(i===timeline.length-1) { %><span style="margin-left:auto;padding:4px 12px;background:var(--blue-dim);border:1px solid rgba(26,80,232,0.3);border-radius:100px;font-size:11px;color:#7ba7ff;font-weight:600;letter-spacing:0.06em">NOW</span><% } %>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CLIENTS -->
<section style="padding:100px 0;background:var(--black);border-top:1px solid rgba(255,255,255,0.06)">
  <div class="container">
    <div class="reveal" style="text-align:center;margin-bottom:64px">
      <div class="section-eyebrow" style="justify-content:center"><span class="section-eyebrow-dot"></span><%= lang==='id' ? 'Klien Kami' : 'Our Clients' %></div>
      <h2 class="section-title"><% if(lang==='id'){ %>Dipercaya oleh<br><span style="color:var(--gray-700)">Perusahaan Terkemuka</span><% } else { %>Trusted by<br><span style="color:var(--gray-700)">Leading Companies</span><% } %></h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:rgba(255,255,255,0.06)" class="reveal">
      <% const clients = ['Bank Jakarta','BRI','Neobank','UOB','Accenture','Telkomsel','IndiHome','Modena','CBI','WGS','Fresh Factory','HW Mandiri','Mitra Bhakti','SIG','Pertamedika','PT.LAPI ITB','Pertamina Hulu Energi','Aegislabs','Unifiber','Accelist']; %>
      <% clients.forEach(c => { %>
      <div style="background:var(--black);padding:24px;display:flex;align-items:center;justify-content:center;transition:background 0.3s" onmouseover="this.style.background='var(--black2)'" onmouseout="this.style.background='var(--black)'">
        <span style="font-size:12px;font-weight:600;color:var(--gray-700);letter-spacing:0.04em;text-align:center;text-transform:uppercase"><%= c %></span>
      </div>
      <% }) %>
    </div>
    <p style="text-align:center;font-size:12px;color:var(--gray-700);margin-top:32px;letter-spacing:0.06em;text-transform:uppercase">
      <%= lang==='id' ? '+ Dan banyak lagi' : '+ And many more' %>
    </p>
  </div>
</section>

<!-- GLOBAL OFFICES -->
<section style="padding:100px 0;background:var(--black2);border-top:1px solid rgba(255,255,255,0.06)">
  <div class="container">
    <div class="reveal" style="margin-bottom:64px">
      <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= lang==='id' ? 'Jangkauan Global' : 'Global Reach' %></div>
      <h2 class="section-title"><% if(lang==='id'){ %>Kantor &<br><span style="color:var(--gray-700)">Cakupan Klien</span><% } else { %>Offices &<br><span style="color:var(--gray-700)">Client Coverage</span><% } %></h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,0.06)">
      <% const offices = [
        { city:'Jakarta', country:'Indonesia', addr:'Graha Binakarsa 7th Floor, Jl. H.R. Rasuna Said Kav C18, South Jakarta', flag:'🇮🇩' },
        { city:'Bandung', country:'Indonesia', addr:'Jl. Komp. Luxor No.5 Kav. 11, Bandung', flag:'🇮🇩' },
        { city:'Hanoi', country:'Vietnam', addr:'3rd Floor, Tan Hong Ha Complex, 317 Truong Chinh Street, Thanh Xuan District', flag:'🇻🇳' },
        { city:'Sydney', country:'Australia', addr:'67 Sanctuary Drive, Beaumont Hills, NSW 2155', flag:'🇦🇺' },
      ]; %>
      <% offices.forEach((o,i) => { %>
      <div class="reveal reveal-delay-<%= i%3 %>" style="background:var(--black2);padding:40px;transition:background 0.3s" onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='var(--black2)'">
        <div style="font-size:28px;margin-bottom:16px"><%= o.flag %></div>
        <h4 style="font-family:var(--font-display);font-size:20px;font-weight:700;color:var(--white);margin-bottom:4px"><%= o.city %></h4>
        <p style="font-size:12px;color:var(--blue);margin-bottom:16px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase"><%= o.country %></p>
        <p style="font-size:13px;color:var(--gray-600);line-height:1.6"><%= o.addr %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section" style="padding-top:0">
  <div class="container">
    <div class="cta-inner reveal">
      <h2><% if(lang==='id'){ %>Kami Tidak Ingin Menjadi Vendor Anda.<br>Kami Ingin Menjadi Mitra Anda.<% } else { %>We Don't Want to Be Your Vendor.<br>We Want to Be Your Partner.<% } %></h2>
      <p><%= lang==='id' ? 'Perbedaannya terlihat dalam cara kami engage — dengan keterlibatan nyata, akuntabilitas outcome, dan hubungan yang melampaui proyek.' : "The difference shows in how we engage — with skin in the game, outcome accountability, and relationships that outlast projects." %></p>
      <div class="cta-btns">
        <a href="/contact" class="btn btn-primary btn-large"><%= lang==='id' ? 'Mulai Percakapan dengan Tim Kami' : 'Start a Conversation With Our Team' %></a>
        <a href="/services" class="btn btn-outline btn-large"><%= lang==='id' ? 'Lihat Layanan' : 'View Services' %></a>
      </div>
    </div>
  </div>
</section>
