const s = serviceContent[service.slug] || null;
const isId = lang === 'id';
%>

<!-- HERO -->
<section class="service-detail-hero">
  <div class="container">
    <a href="/services" class="service-back-link">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= isId ? 'Semua Layanan' : 'All Services' %>
    </a>
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= isId ? 'Layanan' : 'Service' %></div>
    <h1 class="service-detail-title">
      <%= s ? (isId ? s.taglineId : s.taglineEn) : (isId ? service.titleId : service.titleEn) %>
    </h1>
    <p class="service-detail-lede">
      <%= s ? (isId ? s.heroId : s.heroEn) : (isId ? service.descId : service.descEn) %>
    </p>
    <div class="btn-row">
      <a href="/contact" class="btn btn-primary btn-large"><%= isId ? 'Dapatkan Panggilan Diagnostik Gratis' : 'Get a Free Diagnostic Call' %></a>
      <a href="/contact" class="btn btn-outline btn-large"><%= isId ? 'Hubungi Kami' : 'Contact Us' %></a>
    </div>
  </div>
</section>

<% if(s) { %>

<!-- WHY IDEA -->
<section class="section-alt">
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= isId ? 'Mengapa IDEA?' : 'Why IDEA?' %></div>
    <h2 class="heading-section"><%= isId ? 'Yang Membedakan Kami' : 'What Sets Us Apart' %></h2>
    <div class="diff-grid">
      <% const diffs = isId ? s.diffId : s.diffEn; %>
      <% diffs.forEach((d, i) => { %>
      <div class="diff-card reveal">
        <div class="num">0<%= i+1 %></div>
        <h3><%= d[0] %></h3>
        <p><%= d[1] %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- METHODOLOGY -->
<section class="section">
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= isId ? 'Metodologi Kami' : 'Our Methodology' %></div>
    <h2 class="heading-section"><%= isId ? 'Cara Kami Bekerja' : 'How We Work' %></h2>
    <div class="method-list">
      <% const steps = isId ? s.stepsId : s.stepsEn; %>
      <% steps.forEach((step, i) => { %>
      <div class="method-step reveal">
        <div class="num">0<%= i+1 %></div>
        <div>
          <h4><%= step[0] %></h4>
          <p><%= step[1] %></p>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- PROOF POINTS -->
<section class="section-alt section-sm">
  <div class="container">
    <div class="proof-grid">
      <% const proofs = isId ? s.proofsId : s.proofsEn; %>
      <% proofs.forEach(p => { %>
      <div class="proof-card">
        <span class="proof-check">✓</span>
        <p><%= p %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<% } else { %>
<!-- Fallback for services without rich content -->
<section class="section section-sm">
  <div class="container">
    <div class="feature-grid-2">
      <% const features = isId ? service.featuresId : service.features; %>
      <% features.forEach(f => { %>
      <div class="feature-row">
        <span class="bar"></span>
        <span><%= f %></span>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <h2><%= isId ? 'Tidak Yakin Apakah Ini Layanan yang Tepat?' : 'Not Sure If This Is the Right Service for You?' %></h2>
      <p><%= isId ? 'Itulah mengapa kami menawarkan panggilan diagnostik gratis 30 menit. Tanpa kewajiban. Hanya kejelasan tentang apakah dan bagaimana kami bisa membantu.' : "That's exactly why we offer a free 30-minute diagnostic call. No obligation. Just clarity on whether and how we can help." %></p>
      <div class="cta-btns">
        <a href="/contact" class="btn btn-primary btn-large"><%= isId ? 'Dapatkan Panggilan Diagnostik Gratis' : 'Get a Free Diagnostic Call' %></a>
        <a href="/services" class="btn btn-outline btn-large"><%= isId ? 'Layanan Lainnya' : 'Other Services' %></a>
      </div>
    </div>
  </div>
</section>
