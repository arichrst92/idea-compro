<%
// Landing page template — driven entirely by `landing` data from src/routes/landing.js
%>

<!-- HERO -->
<section class="page-hero landing-hero">
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <nav class="product-breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span class="product-breadcrumb-current"><%= landing.h1 %></span>
    </nav>
    <div class="section-eyebrow">
      <span class="section-eyebrow-dot"></span>
      <%= landing.eyebrow %>
    </div>
    <h1><%= landing.h1 %></h1>
    <p class="landing-subhead"><%= landing.subhead %></p>
    <div class="landing-hero-cta">
      <a href="/contact?service=<%= landing.primaryService %>" class="btn btn-primary btn-large">Talk to Our Team</a>
      <a href="https://wa.me/6281805807807?text=<%= encodeURIComponent('Hi IDE Asia, I read your ' + landing.h1 + ' page and want to discuss.') %>" target="_blank" rel="noopener" class="btn btn-outline btn-large">WhatsApp Consultation</a>
    </div>
  </div>
</section>

<!-- BODY SECTIONS -->
<section class="landing-body">
  <div class="container">
    <div class="landing-content">
      <% landing.sections.forEach(s => { %>
        <% if (s.type === 'lead') { %>
          <p class="landing-lead"><%- s.text %></p>
        <% } else if (s.type === 'h2') { %>
          <h2 class="landing-h2"><%= s.text %></h2>
        <% } else if (s.type === 'p') { %>
          <p class="landing-p"><%- s.text %></p>
        <% } else if (s.type === 'bullets') { %>
          <ul class="landing-bullets">
            <% s.items.forEach(item => { %>
              <li>
                <svg class="lb-check" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 9.5l3.5 3.5L14.5 5.5"/></svg>
                <span><%- item %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>
      <% }) %>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="landing-faq">
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span>Questions answered</div>
    <h2 class="landing-h2">Frequently asked questions</h2>
    <div class="landing-faq-list">
      <% landing.faqs.forEach(([q, a], i) => { %>
        <details class="landing-faq-item" <%= i === 0 ? 'open' : '' %>>
          <summary>
            <span><%= q %></span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </summary>
          <div class="landing-faq-answer"><%= a %></div>
        </details>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <h2>Ready to discuss <%= landing.h1 %>?</h2>
      <p>Get a free initial consultation with a senior IDE Asia consultant. Reply within 4 business hours during Jakarta business hours.</p>
      <div class="cta-btns">
        <a href="/contact?service=<%= landing.primaryService %>" class="btn btn-primary btn-large">Book a Consultation</a>
        <a href="/services" class="btn btn-outline btn-large">See All Services</a>
      </div>
    </div>
  </div>
</section>
