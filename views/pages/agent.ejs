<% if (!langExplicit) { %>
<!-- Language picker — shown on first visit so Jarvis sticks to one language -->
<div id="agentLangPicker" class="agent-lang-picker">
  <div class="alp-card">
    <img src="/images/logo-idea.png" alt="IDEA Asia" class="alp-logo">
    <div class="alp-eyebrow">JARVIS · YOUR DIGITAL CONSULTANT</div>

    <!-- Step 1: language -->
    <div id="alpStepLang">
      <h2 class="alp-title">Choose your language<br><span class="alp-sub">Pilih bahasa Anda</span></h2>
      <p class="alp-desc">I'll stick to the language you pick so we stay on the same page.</p>
      <div class="alp-buttons">
        <button type="button" class="alp-btn alp-lang-btn" data-lang="en">
          <span class="alp-flag">EN</span>
          <span class="alp-btn-text"><strong>English</strong><small>Continue in English</small></span>
        </button>
        <button type="button" class="alp-btn alp-lang-btn" data-lang="id">
          <span class="alp-flag">ID</span>
          <span class="alp-btn-text"><strong>Bahasa Indonesia</strong><small>Lanjutkan dalam Bahasa Indonesia</small></span>
        </button>
      </div>
    </div>

    <!-- Step 2: voice (revealed after lang chosen) -->
    <div id="alpStepVoice" style="display:none">
      <h2 class="alp-title alp-title-voice">Choose a voice <span class="alp-optional">(optional)</span></h2>
      <p class="alp-desc" id="alpVoiceDesc">We've picked the best match for your device — feel free to change it.</p>
      <div class="alp-voice-field">
        <label for="alpVoiceSelect" class="alp-voice-label">Jarvis voice</label>
        <select id="alpVoiceSelect" class="alp-voice-select" aria-label="Voice for Jarvis"></select>
      </div>
      <div class="alp-voice-actions">
        <button type="button" id="alpContinue" class="alp-btn-primary">Continue</button>
        <button type="button" id="alpBack" class="alp-btn-secondary">← Back</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Language picker controller — runs INLINE so it's available before agent.js
  // Voice list is platform-specific and only meaningful client-side.
  (function () {
    var pickerEl = document.getElementById('agentLangPicker');
    if (!pickerEl) return;

    var stepLang  = document.getElementById('alpStepLang');
    var stepVoice = document.getElementById('alpStepVoice');
    var selectEl  = document.getElementById('alpVoiceSelect');
    var continueBtn = document.getElementById('alpContinue');
    var backBtn   = document.getElementById('alpBack');
    var descEl    = document.getElementById('alpVoiceDesc');
    var chosenLang = null;

    // Voice load — Chrome / iOS populate asynchronously
    var voices = [];
    function loadVoices() {
      if (!window.speechSynthesis) return;
      voices = window.speechSynthesis.getVoices() || [];
    }
    loadVoices();
    if (window.speechSynthesis && typeof window.speechSynthesis.onvoiceschanged !== 'undefined') {
      window.speechSynthesis.addEventListener('voiceschanged', loadVoices);
    }

    // Recommended order per language — first match wins as "Recommended"
    var EN_RECOMMENDED = [
      'Daniel',                         // iOS/Mac en-GB male (Jarvis tone)
      'Microsoft Mark',                 // Windows en-US male
      'Google UK English Male',         // Android
      'Microsoft David',                // Windows
      'Alex',                           // Mac en-US premium
      'Google US English'               // Android default
    ];
    var ID_RECOMMENDED = [
      'Microsoft Andika',               // Windows id-ID MALE (best)
      'Google bahasa Indonesia',        // Android — gender depends on device
      'Damayanti',                      // iOS/Mac id-ID female (only native)
      'Microsoft Gadis'                 // Windows id-ID female
    ];

    function scoreVoice(voice, recList) {
      var name = (voice.name || '');
      for (var i = 0; i < recList.length; i++) {
        if (name.indexOf(recList[i]) !== -1) return i; // lower = better
      }
      return 999;
    }

    function populateVoices(lang) {
      selectEl.innerHTML = '';
      var prefix = lang === 'id' ? 'id' : 'en';
      var recList = lang === 'id' ? ID_RECOMMENDED : EN_RECOMMENDED;

      var matching = voices.filter(function (v) {
        return v.lang && v.lang.toLowerCase().indexOf(prefix) === 0;
      });

      if (!matching.length) {
        var opt = document.createElement('option');
        opt.textContent = '(No ' + (lang === 'id' ? 'Indonesian' : 'English') + ' voices on this device — using browser default)';
        opt.disabled = true;
        opt.selected = true;
        selectEl.appendChild(opt);
        descEl.textContent = lang === 'id'
          ? 'Perangkat Anda belum memiliki suara Indonesia. Kami akan pakai suara default browser.'
          : 'Your device has no English voices configured. We will use the browser default.';
        return;
      }

      matching.sort(function (a, b) {
        return scoreVoice(a, recList) - scoreVoice(b, recList);
      });

      matching.forEach(function (v, i) {
        var opt = document.createElement('option');
        opt.value = v.name;
        // Show name + lang code; flag the first (recommended)
        var suffix = ' (' + v.lang + ')';
        if (i === 0) suffix += ' — Recommended';
        opt.textContent = v.name + suffix;
        selectEl.appendChild(opt);
      });

      descEl.textContent = lang === 'id'
        ? 'Catatan: di iOS dan macOS, suara Bahasa Indonesia hanya tersedia dalam suara perempuan (Damayanti).'
        : 'For a "Jarvis"-style consultant tone, Daniel (British male) is recommended where available.';
    }

    // Click on language → reveal voice step
    Array.prototype.forEach.call(document.querySelectorAll('.alp-lang-btn'), function (btn) {
      btn.addEventListener('click', function () {
        chosenLang = btn.dataset.lang;
        // If voices not yet loaded, give it a moment
        if (!voices.length && window.speechSynthesis) {
          loadVoices();
          setTimeout(function () {
            loadVoices();
            populateVoices(chosenLang);
          }, 250);
        }
        populateVoices(chosenLang);
        stepLang.style.display = 'none';
        stepVoice.style.display = 'block';
      });
    });

    backBtn.addEventListener('click', function () {
      stepVoice.style.display = 'none';
      stepLang.style.display = 'block';
      chosenLang = null;
    });

    continueBtn.addEventListener('click', function () {
      if (!chosenLang) return;
      var voiceName = selectEl.value || '';
      // Persist explicit user choice — agent.js reads this in pickJarvisVoice
      try {
        if (voiceName) {
          localStorage.setItem('jarvisVoice_' + chosenLang, voiceName);
        } else {
          localStorage.removeItem('jarvisVoice_' + chosenLang);
        }
      } catch (e) { /* private mode */ }
      window.location.href = '/agent?lang=' + chosenLang;
    });
  })();
</script>
<% } %>

<!-- Loading screen -->
<div id="agentLoader">
  <img src="/images/logo-idea.png" alt="IDEA Asia" class="loader-logo">
  <div class="loader-bar-wrap"><div class="loader-bar" id="loaderBar"></div></div>
  <div class="loader-text" id="loaderText">Initializing...</div>
</div>

<!-- Background image -->
<div id="agentBg"></div>

<!-- Particle canvas -->
<canvas id="agentCanvas"></canvas>

<!-- UI overlay -->
<div class="agent-ui">
  <header class="agent-header">
    <a href="/" class="agent-logo">
      <img src="/images/logo-idea.png" alt="IDEA Asia" height="28">
    </a>
    <div class="agent-status">
      <span class="agent-status-dot"></span>
      <span>Jarvis — Online</span>
    </div>
    <div class="view-toggle" title="Switch to website mode">
      <a href="/" class="view-toggle-btn">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><rect x="1" y="1" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/><rect x="8.5" y="1" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/><rect x="1" y="8.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/><rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/></svg>
        <span><%= lang === 'id' ? 'Website' : 'Website' %></span>
      </a>
    </div>
    <a href="/contact" class="view-toggle-btn agent-cta">
      <%= lang === 'id' ? 'Konsultasi Gratis' : 'Free Consultation' %>
    </a>
  </header>

  <!-- Speech bubble -->
  <div class="agent-speech" id="agentSpeech">
    <div class="speech-typing" id="speechTyping">
      <span></span><span></span><span></span>
    </div>
    <div id="speechText" style="display:none"></div>
  </div>

  <!-- Bottom panel -->
  <div class="agent-bottom">
    <!-- Floating action chips (Jarvis CTAs appear here, above the input) -->
    <div id="agentActionsFloating" class="agent-actions-floating"></div>
    <div class="agent-input-area">
      <div class="agent-input-wrap">
        <textarea
          id="agentInput"
          class="agent-input"
          placeholder="<%= lang === 'id' ? 'Tanya saya tentang layanan IT...' : 'Ask me about IT services...' %>"
          rows="1"
          maxlength="1000"
        ></textarea>
        <button id="agentMic" class="agent-mic" aria-label="Voice input">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="6" y="1" width="6" height="10" rx="3" stroke="currentColor" stroke-width="1.8"/>
            <path d="M3 9c0 3.314 2.686 6 6 6s6-2.686 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="9" y1="15" x2="9" y2="17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
        <button id="agentSend" class="agent-send" aria-label="Send">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M15 9H3M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <p class="agent-disclaimer">
        <%= lang === 'id' ? 'Jarvis dapat membuat kesalahan. Untuk keputusan penting, hubungi tim kami.' : 'Jarvis can make mistakes. For critical decisions, consult our team.' %>
        <a href="/contact"><%= lang === 'id' ? 'Hubungi kami' : 'Contact us' %></a>
      </p>
    </div>
  </div>
</div>

