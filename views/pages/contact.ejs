<section class="page-hero">
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span><%= lang==='id' ? 'Hubungi Kami' : 'Contact Us' %></div>
    <h1><% if(lang==='id'){ %>Mulai<br>Percakapan<% } else { %>Start a<br>Conversation<% } %></h1>
    <p><%= lang==='id' ? 'Kami siap mendengar kebutuhan Anda dan membantu menemukan solusi teknologi yang tepat.' : "We're ready to hear your needs and help find the right technology solution for your business." %></p>
  </div>
</section>

<div class="contact-wrap">
  <div class="container">
    <div class="contact-grid">

      <!-- FORM -->
      <div>
        <% if(success) { %>
        <div class="alert alert-success">
          <%= lang==='id' ? '✅ Pesan Anda terkirim! Kami akan menghubungi dalam 1–2 hari kerja.' : '✅ Your message has been sent! We will get back to you within 1–2 business days.' %>
        </div>
        <% } %>
        <% if(error) { %>
        <div class="alert alert-error">
          <%= lang==='id' ? '❌ Terjadi kesalahan. Silakan coba lagi.' : '❌ Something went wrong. Please try again.' %>
        </div>
        <% } %>
        <p class="contact-form-label"><%= lang==='id' ? 'Kirim Pesan' : 'Send a Message' %></p>
        <form action="/contact/submit" method="POST" class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name"><%= lang==='id' ? 'Nama Lengkap *' : 'Full Name *' %></label>
              <input type="text" id="name" name="name" required placeholder="<%= lang==='id' ? 'Nama Anda' : 'Your name' %>">
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="name@company.com">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="company"><%= lang==='id' ? 'Perusahaan' : 'Company' %></label>
              <input type="text" id="company" name="company" placeholder="<%= lang==='id' ? 'Nama perusahaan' : 'Company name' %>">
            </div>
            <div class="form-group">
              <label for="phone"><%= lang==='id' ? 'Nomor Telepon' : 'Phone Number' %></label>
              <input type="tel" id="phone" name="phone" placeholder="+62 821-1567-8446">
            </div>
          </div>
          <div class="form-group">
            <label for="service"><%= lang==='id' ? 'Layanan yang Diminati' : 'Service of Interest' %></label>
            <select id="service" name="service">
              <option value=""><%= lang==='id' ? 'Pilih layanan...' : 'Select a service...' %></option>
              <option value="software-development">Software Development & Integration</option>
              <option value="it-outsourcing">IT Outsourcing</option>
              <option value="it-hiring">Tech Talent Hiring</option>
              <option value="cloud-infrastructure">Cloud Infrastructure</option>
              <option value="it-security">IT Security</option>
              <option value="squad-delivery">Squad Based Delivery</option>
              <option value="ai-development">AI Development</option>
              <option value="managed-service">Managed Service</option>
              <option value="general"><%= lang==='id' ? 'Umum / Lainnya' : 'General / Other' %></option>
            </select>
          </div>
          <div class="form-group">
            <label for="message"><%= lang==='id' ? 'Pesan *' : 'Message *' %></label>
            <textarea id="message" name="message" required placeholder="<%= lang==='id' ? 'Ceritakan tentang proyek atau kebutuhan Anda...' : 'Tell us about your project or requirements...' %>"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">
            <%= lang==='id' ? 'Kirim Pesan — Kami Respons Dalam 4 Jam' : 'Send Message — We\'ll Respond Within 4 Hours' %>
          </button>
        </form>
        <div class="form-divider">
          <p class="or"><%= lang==='id' ? 'ATAU' : 'OR' %></p>
          <a href="https://wa.me/6282115678446" target="_blank" rel="noopener" class="btn-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <%= lang==='id' ? 'Chat di WhatsApp Sekarang' : 'Chat on WhatsApp Now' %>
          </a>
        </div>
      </div>

      <!-- INFO -->
      <div class="contact-info">
        <h3><%= lang==='id' ? 'Informasi Kontak' : 'Contact Information' %></h3>
        <p><%= lang==='id' ? 'Atau langsung hubungi kami melalui salah satu saluran berikut.' : 'Or reach us directly through one of the following channels.' %></p>
        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="14" height="11" rx="1.5"/><path d="M2 5l7 5 7-5"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Email</strong>
              <span><a href="mailto:info@ide.asia">info@ide.asia</a></span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 2.5h2.2l1.6 4-2.2 1.1c.9 1.9 2.5 3.5 4.4 4.4l1.1-2.2 4 1.6V14a1.5 1.5 0 0 1-1.5 1.5C6.8 15.5 2.5 11.2 2.5 4A1.5 1.5 0 0 1 3.5 2.5z"/></svg>
            </div>
            <div class="contact-item-text">
              <strong><%= lang==='id' ? 'Telepon / WhatsApp' : 'Phone / WhatsApp' %></strong>
              <span><a href="tel:+6282115678446">+62 821-1567-8446</a></span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="7"/><path d="M2 9h14"/><path d="M9 2c2.2 2 3.3 4.6 3.3 7s-1.1 5-3.3 7c-2.2-2-3.3-4.6-3.3-7s1.1-5 3.3-7z"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Website</strong>
              <span><a href="https://www.ide.asia" target="_blank" rel="noopener">www.ide.asia</a></span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 16s5-5.4 5-9.5A5 5 0 0 0 4 6.5C4 10.6 9 16 9 16z"/><circle cx="9" cy="7" r="1.8"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Jakarta (HQ) · Indonesia</strong>
              <span>Graha Binakarsa 7th Floor, Jl. H.R. Rasuna Said Kav C18, South Jakarta</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 16s5-5.4 5-9.5A5 5 0 0 0 4 6.5C4 10.6 9 16 9 16z"/><circle cx="9" cy="7" r="1.8"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Bandung · Indonesia</strong>
              <span>Jl Setramurni Tengah IV No 33, Bandung</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 16s5-5.4 5-9.5A5 5 0 0 0 4 6.5C4 10.6 9 16 9 16z"/><circle cx="9" cy="7" r="1.8"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Hanoi · Vietnam</strong>
              <span>3rd Floor, Tan Hong Ha Complex, 317 Truong Chinh Street, Thanh Xuan District</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 16s5-5.4 5-9.5A5 5 0 0 0 4 6.5C4 10.6 9 16 9 16z"/><circle cx="9" cy="7" r="1.8"/></svg>
            </div>
            <div class="contact-item-text">
              <strong>Sydney · Australia</strong>
              <span>67 Sanctuary Drive, Beaumont Hills, NSW 2155</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-item-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="7"/><path d="M9 5v4l2.5 1.5"/></svg>
            </div>
            <div class="contact-item-text">
              <strong><%= lang==='id' ? 'Jam Operasional' : 'Business Hours' %></strong>
              <span><%= lang==='id' ? 'Senin – Jumat, 09.00 – 18.00 WIB' : 'Monday – Friday, 9AM – 6PM WIB' %></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
