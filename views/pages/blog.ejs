<section class="page-hero">
  <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <div class="section-eyebrow"><span class="section-eyebrow-dot"></span>Blog</div>
    <h1 class="section-title"><%= lang === 'id' ? 'Wawasan & Artikel' : 'Insights & Articles' %></h1>
    <p>
      <%= lang === 'id' ? 'Panduan, tren, dan wawasan seputar IT Consulting, Cloud, Keamanan, dan Transformasi Digital.' : 'Guides, trends and insights on IT Consulting, Cloud, Security and Digital Transformation.' %>
    </p>
  </div>
</section>

<div class="blog-filters-bar">
  <div class="container">
    <div class="blog-filters">
      <a href="/blog" class="filter-btn <%= !category ? 'active' : '' %>"><%= lang === 'id' ? 'Semua' : 'All' %></a>
      <a href="/blog?category=it-consulting" class="filter-btn <%= category === 'it-consulting' ? 'active' : '' %>">IT Consulting</a>
      <a href="/blog?category=it-outsourcing" class="filter-btn <%= category === 'it-outsourcing' ? 'active' : '' %>">IT Outsourcing</a>
      <a href="/blog?category=it-hiring" class="filter-btn <%= category === 'it-hiring' ? 'active' : '' %>">IT Hiring</a>
      <a href="/blog?category=cloud-infrastructure" class="filter-btn <%= category === 'cloud-infrastructure' ? 'active' : '' %>">Cloud</a>
      <a href="/blog?category=it-security" class="filter-btn <%= category === 'it-security' ? 'active' : '' %>">IT Security</a>
      <a href="/blog?category=squad-delivery" class="filter-btn <%= category === 'squad-delivery' ? 'active' : '' %>">Squad Delivery</a>
    </div>
  </div>
</div>

<div class="blog-list-wrap">
  <div class="container">
    <% if (blogs.length === 0) { %>
    <div class="blog-empty">
      <p><%= lang === 'id' ? 'Belum ada artikel. Bot akan segera menghasilkan konten baru.' : 'No articles yet. The bot will generate new content soon.' %></p>
    </div>
    <% } else { %>
    <div class="blog-grid">
      <% blogs.forEach(blog => { %>
      <article class="blog-card reveal">
        <div class="blog-card-cat"><%= blog.category.replace(/-/g,' ') %></div>
        <h3><a href="/blog/<%= blog.slug %>"><%= lang === 'id' && blog.titleId ? blog.titleId : blog.title %></a></h3>
        <p><%= lang === 'id' && blog.excerptId ? blog.excerptId.substring(0,120) : blog.excerpt.substring(0,120) %>...</p>
        <div class="blog-card-meta">
          <span><%= new Date(blog.createdAt).toLocaleDateString(lang === 'id' ? 'id-ID' : 'en-US', {year:'numeric',month:'short',day:'numeric'}) %></span>
          <span><%= blog.readTime %> min read</span>
        </div>
      </article>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %><a href="/blog?page=<%= page-1 %><%= category ? '&category='+category : '' %>" class="page-btn">‹</a><% } %>
      <% for(let i=1; i<=totalPages; i++) { %>
      <a href="/blog?page=<%= i %><%= category ? '&category='+category : '' %>" class="page-btn <%= i===page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <% if (page < totalPages) { %><a href="/blog?page=<%= page+1 %><%= category ? '&category='+category : '' %>" class="page-btn">›</a><% } %>
    </div>
    <% } %>
    <% } %>
  </div>
</div>
